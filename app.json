{
  "expo": {
    "name": "YSClaude",
    "slug": "YSClaude",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ysclaude",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "backgroundImage": "./assets/android-icon-background.png",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "android.permission.FOREGROUND_SERVICE_SPECIAL_USE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_CALENDAR",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_CALENDAR"
      ],
      "usesCleartextTraffic": true,
      "package": "com.ysclaude.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/Sohne-Buch.otf",
            "./assets/Sohne-Halbfett.otf",
            "./assets/SohneMono-Buch.otf",
            "./assets/TiemposText.otf",
            "./assets/TiemposText-bold.otf"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "sounds": [
            "./assets/messagealert.mp3"
          ]
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "允许 YSClaude 读取和管理你的日历日程，以便在你开启日历 Tool 后执行日程相关请求。",
          "remindersPermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "允许 YSClaude 访问相册，以便保存 AI 生成的图片。",
          "savePhotosPermission": "允许 YSClaude 将 AI 生成的图片保存到相册。",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-asset",
      [
        "expo-sharing",
        {
          "android": {
            "enabled": true,
            "singleShareMimeTypes": [
              "text/plain",
              "text/*"
            ],
            "multipleShareMimeTypes": [
              "text/plain",
              "text/*"
            ]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3660e22f-35ac-4218-bf72-6a6489d0faee"
      }
    },
    "owner": "linwang_004"
  }
}
